DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/eod_settlement
CORS_ORIGINS=["http://localhost:5173"]

# JWT Auth
SECRET_KEY=change-me-run-python-secrets-token-urlsafe-32
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Database connection pool
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# SMTP for EOD notifications (leave blank to disable)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=eod@settlement.local
NOTIFICATION_EMAILS=[]
